programa {
  funcao inicio() {
    inteiro litros, distancia, consumo

    escreva("Quantos KM foram percorridos? ")
    leia(distancia)

    escreva("Quantos litros foram gastos? ")
    leia(litros)


     consumo = litros / distancia

    escreva("consumo medio de (KM/L): ")
    escreva(consumo)
  }
}
