programa {
  funcao inicio() {
    inteiro i, j, valor
    inteiro m[3][3]
    inteiro v[5]

   para (i = 0; i <= 2; i++) {
   para (j = 0; j <= 2; j++) {
      escreva("Digite: ")
      leia(m[i][j])
   }
}

valor = m[2][2]

 para (i = 0; i <= 4; i++) {
   v[i] = valor * 10
   escreva(v[i], " ")
}
  }
}
